# Optional fallback for the OpenAI Audio API route.
OPENAI_API_KEY=

# Optional local Codex OAuth bridge. The app still runs without this,
# but OAuth enables the GPT-5.5 manifest route and Realtime TTS route.
OPENAI_OAUTH_ROOT=/absolute/path/to/openao-oauth-access
OPENAI_REALTIME_MODEL=gpt-realtime-2
OPENAI_REALTIME_REASONING_EFFORT=xhigh

# Optional Gemini API text-to-speech provider from Google AI Studio.
GEMINI_API_KEY=
GEMINI_TTS_MODEL=gemini-3.1-flash-tts-preview
GEMINI_TTS_VOICE=Charon

# Optional Google Cloud Text-to-Speech provider for Korean pronunciation tests.
# Use one auth path:
# 1) API key:
GOOGLE_TTS_API_KEY=
# 2) OAuth access token:
GOOGLE_TTS_ACCESS_TOKEN=
# 3) Local gcloud OAuth, if gcloud is installed and logged in:
GOOGLE_TTS_USE_GCLOUD=0
GOOGLE_TTS_PROJECT_ID=
GOOGLE_TTS_VOICE=ko-KR-Chirp3-HD-Charon
GOOGLE_TTS_SPEAKING_RATE=0.94
GOOGLE_TTS_PITCH=-1

# Optional local macOS TTS provider. This is free and exportable on Macs
# that have Korean system voices installed.
MACOS_TTS_VOICE=Yuna
MACOS_TTS_RATE=170
PORT=5173
